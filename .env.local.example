# Local SQLite (default — no setup required)
# DB_DRIVER=sqlite
# SQLITE_PATH=./data/cricket-score.db

# When testing from other devices on your network, set this to your LAN URL so
# share links work on phones (e.g. http://192.168.1.5:3000).
# NEXT_PUBLIC_APP_ORIGIN=http://192.168.1.5:3000

# Neon Postgres (production / optional local)
# DB_DRIVER=postgres
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
